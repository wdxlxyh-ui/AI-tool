# Edge-EMS 部署工具配置文件

# ==================== Azure Blob 配置 ====================
# Azure SAS 令牌（必填）
# 获取方式：
# 1. 登录 https://portal.azure.com
# 2. 搜索 "Storage Account"
# 3. 找到 edgeadls2 Blob 容器
# 4. 生成 SAS 令牌并复制
AZURE_BLOB_SAS_TOKEN=your-sas-token-here

# 本地镜像目录（Blob 下载后的保存位置）
BLOB_MIRROR_DIR=/mnt/d/Blob

# 日志目录
LOG_DIR=/tmp/edge-ems-deploy-logs

# ==================== 服务器凭据 ====================
# HPUY 服务器配置
HPUY_SSH_USER=admin
HPUY_SSH_PASSWORD=EdgeLoggerSys@1024
HPUY_SSH_HOST=your-hpuy-server-ip
HPUY_SSH_PORT=9991
HPUY_REMOTE_BASE_DIR=/root/EMS/

# EE 服务器配置
EE_SSH_USER=root
EE_SSH_PASSWORD=YourEEPassword
EE_SSH_HOST=your-ee-server-ip
EE_SSH_PORT=9991
EE_REMOTE_BASE_DIR=/home/envuser/energy-os/

# ==================== 部署配置 ====================
# 默认分支
DEFAULT_BRANCH=develop_2605

# 默认服务器类型
DEFAULT_SERVER=HPUY

# 默认组件
DEFAULT_COMPONENT=all

# 是否启用详细日志
ENABLE_DEBUG_LOG=false

# ==================== 高级配置 ====================
# 下载超时时间（秒）
DOWNLOAD_TIMEOUT=300

# SSH 超时时间（秒）
SSH_TIMEOUT=120

# 最大重试次数
MAX_RETRIES=3

# 连接超时时间（秒）
CONNECT_TIMEOUT=10
